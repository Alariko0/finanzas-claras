# FinanzasClaras - Variables de entorno
# Copia este archivo como .env y rellena con tus valores

# Puerto del servidor
PORT=3001

# MongoDB URI (cambia por tu instancia local o MongoDB Atlas)
# Para MongoDB Atlas: https://cloud.mongodb.com/
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/finanzas-claras?retryWrites=true&w=majority

# MongoDB local (descomenta para desarrollo local)
# MONGODB_URI=mongodb://localhost:27017/finanzas-claras

# Configuración de autenticación JWT (Fase 3)
# Generar un secreto único con: openssl rand -hex 32
JWT_SECRET=fc_jwt_secret_change_me_to_a_secure_random_string
JWT_EXPIRES_IN=7d

# Secret para firma de enlaces compartidos
SHARED_LINK_SECRET=fc_shared_link_secret_change_me

# CORS (origen permitido)
# Puedes añadir múltiples con comas
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=info

# Modo de desarrollo
NODE_ENV=development

# Rate limiting (opcional)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Seguridad: limitar acceso a IP específica (opcional)
# RATE_LIMIT_BY_IP=true

# Rate limit por usuario (opcional)
# RATE_LIMIT_PER_USER=true