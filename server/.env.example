# FinanzasClaras - Variables de entorno
# Copia este archivo como .env y rellena con tus valores

# Puerto del servidor
PORT=3001

# MongoDB URI (cambia por tu instancia local o MongoDB Atlas)
MONGODB_URI=mongodb://localhost:27017/finanzas-claras

# Configuración de autenticación JWT (Fase 3)
JWT_SECRET=finanzas-claras-secret-key-change-in-production-2025
JWT_EXPIRES_IN=7d

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=info

# Modo de desarrollo
NODE_ENV=development
